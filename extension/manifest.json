{
  "manifest_version": 3,
  "name": "Recall",
  "version": "1.0.0",
  "description": "Generate personalized MCQs and flash cards from your notes",
  "permissions": ["storage", "activeTab", "identity"],
  "host_permissions": ["http://localhost:3001/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Recall - Study Smarter"
  },
  "oauth2": {
    "client_id": "751339140299-tl0lcurv051kp3gapcff4iigf51qli94.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "scripts/widget/widget-shared.js",
        "scripts/widget/widget-runtime.js",
        "scripts/widget/widget-storage.js",
        "scripts/widget/widget-ui.js",
        "scripts/widget/widget-card-render-helpers.js",
        "scripts/widget/content-widget.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
